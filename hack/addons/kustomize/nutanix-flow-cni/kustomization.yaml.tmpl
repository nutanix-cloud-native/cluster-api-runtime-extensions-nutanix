apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

metadata:
  name: nutanix-flow-cni

sortOptions:
  order: fifo

helmCharts:
- name: nutanix-flow-cni
  repo: https://nutanix.github.io/helm-releases
  releaseName: nutanix-flow-cni
  version: ${NUTANIX_FLOW_CNI_VERSION}
  includeCRDs: true
  skipTests: true
  namespace: kube-system

namespace: kube-system
